[user]
  name = Sam McDavid
  email = sam@mcdavid.us
  signingkey = ED12FA079CD7B57D
[filter "hawser"]
  clean = git hawser clean %f
  smudge = git hawser smudge %f
  required = true
[core]
  editor = nvim
  excludesfile = ~/.gitignore_global
[commit]
  template = ~/.gitmessage
  gpgsign = true
[credential]
  helper = osxkeychain
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[init]
  defaultBranch = main
[pager]
  branch = false
[includeIf "gitdir:~/Developer/work/"]
  path = ~/.gitconfig-work
[includeIf "gitdir:~/Developer/personal/"]
  path = ~/.gitconfig-personal
