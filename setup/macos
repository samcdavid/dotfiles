#!/bin/sh

# macOS preferences
# Run on a fresh install to configure system defaults.
# Some changes require a logout/restart to take effect.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

fancy_echo() {
  local fmt="$1"; shift
  # shellcheck disable=SC2059
  printf "\n$fmt\n" "$@"
}

# Dock
fancy_echo "Configuring Dock..."
defaults write com.apple.dock autohide -bool true

# Finder
fancy_echo "Configuring Finder..."
defaults write com.apple.finder FXPreferredViewStyle -string "clmv"

# Trackpad: tap to click
fancy_echo "Configuring trackpad..."
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true

# Cursor size (larger for 4K monitors, default is 1.0)
fancy_echo "Configuring cursor size..."
defaults write com.apple.universalaccess mouseDriverCursorSize -float 2.0

# Text replacements (looks of disapproval)
fancy_echo "Setting up text replacements..."
SCRIPT_DIR="$SCRIPT_DIR" python3 << 'PYEOF'
import plistlib, subprocess, tempfile, os

replacements_path = os.path.join(os.environ["SCRIPT_DIR"], "text-replacements.plist")
with open(replacements_path, 'rb') as f:
    replacements = plistlib.load(f)

# Export current global domain
with tempfile.NamedTemporaryFile(suffix='.plist', delete=False) as tf:
    current_path = tf.name

subprocess.run(['defaults', 'export', '-g', current_path], check=True)

with open(current_path, 'rb') as f:
    prefs = plistlib.load(f)

# Keep any manually added replacements (not using $$ pattern), merge ours in
existing = prefs.get('NSUserDictionaryReplacementItems', [])
manual = [r for r in existing if not r.get('replace', '').startswith('$$')]
prefs['NSUserDictionaryReplacementItems'] = manual + replacements

with open(current_path, 'wb') as f:
    plistlib.dump(prefs, f)

subprocess.run(['defaults', 'import', '-g', current_path], check=True)
os.unlink(current_path)

print(f"  Imported {len(replacements)} text replacements.")
PYEOF

# Apply Dock and Finder changes
killall Dock 2>/dev/null
killall Finder 2>/dev/null

fancy_echo "macOS preferences configured. Some changes may require logout/restart."
