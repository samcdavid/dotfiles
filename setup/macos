#!/bin/sh

# macOS preferences
# Run on a fresh install to configure system defaults.
# Some changes require a logout/restart to take effect.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

fancy_echo() {
  local fmt="$1"; shift
  # shellcheck disable=SC2059
  printf "\n$fmt\n" "$@"
}

# Dock
fancy_echo "Configuring Dock..."
defaults write com.apple.dock autohide -bool true

# Finder
fancy_echo "Configuring Finder..."
defaults write com.apple.finder FXPreferredViewStyle -string "clmv"

# Trackpad: tap to click
fancy_echo "Configuring trackpad..."
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true

# Text replacements (looks of disapproval)
# macOS stores these in a SQLite database, not defaults
fancy_echo "Setting up text replacements..."
SCRIPT_DIR="$SCRIPT_DIR" python3 << 'PYEOF'
import plistlib, sqlite3, os, uuid, time

replacements_path = os.path.join(os.environ["SCRIPT_DIR"], "text-replacements.plist")
with open(replacements_path, 'rb') as f:
    replacements = plistlib.load(f)

db_path = os.path.expanduser("~/Library/KeyboardServices/TextReplacements.db")
conn = sqlite3.connect(db_path)
c = conn.cursor()

# Get the current max primary key and Z_MAX for the entity
c.execute("SELECT COALESCE(MAX(Z_PK), 0) FROM ZTEXTREPLACEMENTENTRY")
max_pk = c.fetchone()[0]

# Core Data epoch: 2001-01-01T00:00:00Z
cd_epoch = 978307200
timestamp = time.time() - cd_epoch

added = 0
for r in replacements:
    shortcut = r.get("replace", "")
    phrase = r.get("with", "")
    if not shortcut or not phrase:
        continue

    # Skip if this shortcut already exists and isn't deleted
    c.execute("SELECT Z_PK FROM ZTEXTREPLACEMENTENTRY WHERE ZSHORTCUT = ? AND ZWASDELETED = 0", (shortcut,))
    if c.fetchone():
        continue

    max_pk += 1
    unique_name = str(uuid.uuid4()).upper()
    c.execute("""
        INSERT INTO ZTEXTREPLACEMENTENTRY
        (Z_PK, Z_ENT, Z_OPT, ZNEEDSSAVETOCLOUD, ZWASDELETED, ZTIMESTAMP, ZPHRASE, ZSHORTCUT, ZUNIQUENAME)
        VALUES (?, 1, 1, 1, 0, ?, ?, ?, ?)
    """, (max_pk, timestamp, phrase, shortcut, unique_name))
    added += 1

# Update Z_PRIMARYKEY so Core Data stays consistent
c.execute("UPDATE Z_PRIMARYKEY SET Z_MAX = ? WHERE Z_ENT = 1", (max_pk,))

conn.commit()
conn.close()
print(f"  Imported {added} text replacements.")
PYEOF

# Apply changes
killall Dock 2>/dev/null
killall Finder 2>/dev/null
killall cfprefsd 2>/dev/null

fancy_echo "macOS preferences configured. Some changes may require logout/restart."
